{
  "framework": "vite",
  "installCommand": "cd medicine-billing-frontend && npm install",
  "buildCommand": "cd medicine-billing-frontend && npm run build",
  "outputDirectory": "medicine-billing-frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ankit-doctor-billing-backend.vercel.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
